  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler",
    "jsx": "react-jsx", "strict": true, "skipLibCheck": true,
    "allowImportingTsExtensions": false, "isolatedModules": true,
    "esModuleInterop": true, "lib": ["ES2022","DOM","DOM.Iterable"]
